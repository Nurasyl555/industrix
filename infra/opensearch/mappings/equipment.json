{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0
  },
  "mappings": {
    "dynamic_templates": [
      {
        "technical_attributes": {
          "match_mapping_type": "string",
          "path_match": "specs.*",
          "mapping": {
            "type": "keyword"
          }
        }
      }
    ],
    "properties": {
      "id": {
        "type": "keyword"
      },
      "title": {
        "type": "text",
        "analyzer": "standard"
      },
      "description": {
        "type": "text",
        "analyzer": "standard"
      },
      "category_id": {
        "type": "keyword"
      },
      "price": {
        "type": "double"
      },
      "currency": {
        "type": "keyword"
      },
      "location": {
        "type": "geo_point"
      },
      "city_id": {
        "type": "keyword"
      },
      "created_at": {
        "type": "date"
      },
      "updated_at": {
        "type": "date"
      },
      "status": {
        "type": "keyword"
      },
      "tags": {
        "type": "keyword"
      }
    }
  }
}
