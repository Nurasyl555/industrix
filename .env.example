# Industrix Environment Variables
# Copy this file to .env and fill in your values

# ===================
# Application Environment
# ===================
ENV=development
DEBUG=true
LOG_LEVEL=debug

# ===================
# Database Configuration
# ===================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=postgres

# ===================
# MongoDB Configuration
# ===================
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=chat_db

# ===================
# Redis Configuration
# ===================
REDIS_HOST=redis
REDIS_PORT=6379

# Redis Cache instance
REDIS_CACHE_DB=0

# Redis Session instance
REDIS_SESSION_DB=1

# ===================
# Kafka Configuration
# ===================
KAFKA_BROKERS=kafka:29092
KAFKA_CONSUMER_GROUP=industrix-consumer-group

# ===================
# OpenSearch Configuration
# ===================
OPENSEARCH_HOSTS=http://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ===================
# MinIO Configuration
# ===================
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_BUCKETS=equipment-media,documents,chat-files,dispute-evidence

# ===================
# JWT Configuration
# ===================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ===================
# External APIs
# ===================

# 2GIS API (Geocoding & Routing)
TWOGIS_API_KEY=your-2gis-api-key

# SMS Providers
SMS_PROVIDER=test
SMS_API_KEY=your-sms-api-key
SMS_SENDER=INDUSTRIX

# Push Notifications
FCM_SERVER_KEY=your-fcm-server-key
APNS_KEY_PATH=/path/to/apns-key.p8
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id

# ===================
# Email Configuration (Postal SMTP)
# ===================
SMTP_HOST=postal
SMTP_PORT=25
SMTP_USERNAME=postal
SMTP_PASSWORD=postal-password
SMTP_FROM=noreply@industrix.local

# ===================
# Gotenberg (PDF Generation)
# ===================
GOTENBERG_URL=http://gotenberg:3000

# ===================
# imgproxy (Image Processing)
# ===================
IMGPROXY_URL=http://imgproxy:8080
IMGPROXY_SECRET=your-imgproxy-signing-key

# ===================
# Payment Providers
# ===================

# Kaspi Pay
KASPI_MERCHANT_ID=your-kaspi-merchant-id
KASPI_API_KEY=your-kaspi-api-key

# Halyk Bank
HALYK_MERCHANT_ID=your-halyk-merchant-id
HALYK_API_KEY=your-halyk-api-key


# ===================
# Service URLs (Internal)
# ===================
GATEWAY_URL=http://gateway:8080
IDENTITY_SERVICE_URL=identity:8081
CATALOG_SERVICE_URL=catalog:8082
LISTING_SERVICE_URL=listing:8083
SEARCH_SERVICE_URL=search:8084
BOOKING_SERVICE_URL=booking:8085
DEAL_SERVICE_URL=deal:8086
PAYMENT_SERVICE_URL=payment:8087
DOCUMENT_SERVICE_URL=document:8088
REVIEW_SERVICE_URL=review:8089
SERVICES_MARKETPLACE_URL=services-marketplace:8090
CHAT_SERVICE_URL=chat:8091
NOTIFICATION_SERVICE_URL=notification:8092
ENGAGEMENT_SERVICE_URL=engagement:8093
INTEGRITY_SERVICE_URL=integrity:8094
MEDIA_SERVICE_URL=media:8095
ANALYTICS_SERVICE_URL=analytics:8096
ADMIN_SERVICE_URL=admin:8097

# ===================
# Frontend Configuration
# ===================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===================
# Observability
# ===================

# Jaeger Tracing
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Grafana
GRAFANA_URL=http://localhost:3002
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# ===================
# Feature Flags
# ===================
FEATURE_PAYMENTS_ENABLED=true
FEATURE_ESCROW_ENABLED=true
FEATURE_RENTAL_ENABLED=true
FEATURE_CHAT_ENABLED=true
